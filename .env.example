# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=False

# Admin SDK credentials: either use a service account JSON file (GOOGLE_APPLICATION_CREDENTIALS)
# or extract these two values from the file. Never commit the JSON file to the repository.
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-<REPLACE>@<PROJECT-id>.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY=""

# Auth Cookie Signature Keys (for next-firebase-auth-edge)
# Keys should be at least 32 bytes in length. (Any value is fine for local development.)
AUTH_COOKIE_SIGNATURE_KEY_CURRENT="78o7oafcT!An3Vhv5oGNMA%bsutjuMvz"  # Random value for local development
AUTH_COOKIE_SIGNATURE_KEY_PREVIOUS=""
USE_SECURE_COOKIES=false

# Path to service account JSON file.
# IMPORTANT: Keep this file OUTSIDE the project directory (e.g., ~/.config/firebase/...)
# to prevent accidental commits. The .gitignore excludes *firebase-adminsdk*.json,
# but using an external path is an additional safety layer.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json

# Optional: Analytics
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Moonshot AI (Kimi) API Key
MOONSHOT_API_KEY=""
# Openrouter API Key
OPENROUTER_API_KEY=""

# Rate Limiting (requests per day per user)
RATE_LIMIT_REQUESTS_PER_DAY=10
RATE_LIMIT_MAX_TOKENS=1024